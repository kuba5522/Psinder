@model Psinder.Models.Post

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<head>
<style >
    
    div{
        color: white
        }
    
    .przyciski { 
        display: flex;
        justify-content: space-evenly;
        align-items: center;
        padding: 10px;
        margin: 10px;
        background-color: brak;           <!-- Tutaj dodać kolor naglówka, jeśli brak to jest od tła strony -->
        }

    .btn {
        color: #f5f5f5;
      }

    .new_post_container {
        background: rgba(217, 217, 217, 0.5);
        backdrop-filter: blur(2px);
        padding: 10px 10px 10px 10px;

      }


    .control-label-psinder {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-size: 15px;
        line-height: 24px;
        @* display: flex; *@
        @* align-items: center; *@
        @* justify-content: center; *@
        margin-bottom: 0;

        color: #FFFFFF

    }

    .new_post_text {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-size: 20px;
        line-height: 24px;
        display: flex;
        align-items: center;
        @* text-align: center; *@
        justify-content: center;
        margin-bottom: 0;

        color: #FFFFFF;
      } 
    
    .contact_details_text{
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-size: 20px;
        line-height: 24px;
        @* display: flex;
        align-items: center; *@
        @* text-align: center; *@
        justify-content: right: ;;
        margin-bottom: 0;
        color: #FFFFFF;
        margin: 30px 0px 0px 0px;
      }
    
    .form-group{
        width: 100%;

    }


    
</style>
 <script>
          var loadFile = function(event) {
              var image = document.getElementById('output');
              image.src=URL.createObjectURL(event.target.files[0]);
          };
      </script>

</head>
      
<body>

<h1>Create</h1>

<h4>Post</h4>
<div class="przyciski">
        
      <button type="button" class="btn">&larr; wróć do ogłoszeń</button>
      <button type="button" class="btn">+ dodaj ogłoszenie</button>
     
      <!-- <button>Przycisk 1</button> -->
    </div>

<div class="new_post_container">
        <p class="new_post_text">Nowe ogłoszenie</p>


    </div>


<div class="row">
    <form asp-action="Create" enctype = "multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div>
        <div class="form-group">
            <label asp-for="Title" class="control-label-psinder"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Description" class="control-label-psinder"></label>
            <input asp-for="Description" class="form-control" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
    </div>
    <div>    
        <div>
            <img src="../Pies_to_add_image" style = "width:75px">
        </div>
        <div class="col-md-5" style="float: left; width: 45%;margin-right: 5%;">
            <div class="form-group">
            <label for="Image"></label>
            <input type ="file" name="Image" accept="image/*" onchange="loadFile(event)"/>
            </div>
            <div class="form-group">
                <label asp-for="Name" class="control-label-psinder"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-5" style="float: right;width: 45%;margin-right: 5%;">
            <div class="form-group">
                <label asp-for="Breed" class="control-label-psinder"></label>
                <input asp-for="Breed" class="form-control" />
                <span asp-validation-for="Breed" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Age" class="control-label-psinder"></label>
                <input asp-for="Age" class="form-control" />
                <span asp-validation-for="Age" class="text-danger"></span>
            </div>
@* 
                    <div class="form-group">
                        <label asp-for="Difficulty" class="control-label-psinder"></label>
                        <input asp-for="Difficulty" class="form-control" />
                        <span asp-validation-for="Difficulty" class="text-danger"></span>
                    </div> *@

            <div class="form-group">
                <label asp-for="Size" class="control-label-psinder"></label>
                <input asp-for="Size" class="form-control" />
                <span asp-validation-for="Size" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Location" class="control-label-psinder"></label>
                <input asp-for="Location" class="form-control" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>
        </div>
    </div>
    <div>        
        <div class="contact_details_text">
        <p>Dane kontaktowe</p>
        </div>

            
@*            <div class="form-group">
                <label asp-for="ImagePath" class="control-label-psinder"></label>
                <input asp-for="ImagePath" class="form-control" />
                <span asp-validation-for="ImagePath" class="text-danger"></span>
            </div>*@
        <div class="col-md-5" "float: left; width: 45%;margin-right: 5%;">
            <p><img id="output" width="200"/></p>
            <div class="form-group">
                <label asp-for="ContactPhone" class="control-label-psinder"></label>
                <input asp-for="ContactPhone" class="form-control" />
                <span asp-validation-for="ContactPhone" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-5" "float: right; width: 45%;margin-right: 5%;">
            <div class="form-group">
                <label asp-for="ContactEmail" class="control-label-psinder"></label>
                <input asp-for="ContactEmail" class="form-control" />
                <span asp-validation-for="ContactEmail" class="text-danger"></span>
            </div>  
    </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </div>
    </form>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
</body>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
